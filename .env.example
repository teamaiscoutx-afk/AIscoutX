# Copy to .env.local — https://supabase.com/dashboard

# Supabase (required for auth + dashboard data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: seed script + admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth / email redirect base
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Live Intelligence Engine (required for real signals, no mock data) ---
# Web search — configure at least one:
TAVILY_API_KEY=tvly-your-key
# SERPER_API_KEY=your-serper-key
# PERPLEXITY_API_KEY=pplx-your-key

# LLM synthesis — configure at least one:
OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
