# Copy to .env.local — https://supabase.com/dashboard

# Supabase (required for auth + dashboard data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: seed script + admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# One-time feed seed via POST /api/admin/seed-opportunities (Bearer token)
SEED_SECRET=choose-a-long-random-string

# OAuth / email redirect base
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Live Intelligence Engine (required for real signals, no mock data) ---
# Web search — configure at least one:
TAVILY_API_KEY=tvly-your-key
# SERPER_API_KEY=your-serper-key
# PERPLEXITY_API_KEY=pplx-your-key

# LLM synthesis — configure at least one:
OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Billing (Razorpay) ---
# Live keys from Razorpay Dashboard → Account & Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
# Webhook signing secret (Razorpay Dashboard → Webhooks → /api/webhooks/razorpay)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Optional: recurring subscription plan id (Razorpay Dashboard → Subscriptions → Plans)
# If omitted, checkout uses a one-time order for the amount below.
RAZORPAY_PRO_PLAN_ID=plan_your-plan-id
# Amount in smallest currency unit (cents for USD). Default: 1900 = $19
RAZORPAY_PRO_AMOUNT=1900
RAZORPAY_CURRENCY=USD

# Legacy Stripe (optional — kept for existing deployments)
# STRIPE_PRO_PAYMENT_LINK=https://buy.stripe.com/your-link
# STRIPE_WEBHOOK_SECRET=whsec_your-secret

# --- Transactional email (Resend) ---
RESEND_API_KEY=re_your-key
EMAIL_FROM="AIscoutX <hello@aiscoutx.com>"
